{
  "name": "@your-org/design-system",
  "version": "0.1.0",
  "description": "A clean, minimal React + TypeScript design system built on CSS Modules and CSS variables.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./dist/index.css": "./dist/index.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsup",
    "prepare": "tsup",
    "build:watch": "tsup --watch",
    "build:docs": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0"
  },
  "sideEffects": [
    "**/*.css",
    "dist/index.css"
  ],
  "dependencies": {
    "pixelarticons": "^2.1.2",
    "react-markdown": "^10.1.0"
  }
}
